# ─── Mercado / banco ───────────────────────────────────────
# BANK_PAYMENT_TYPE: payType de Binance (descúbrelo con discover_paytypes.py)
# BANK_DISPLAY_NAME: nombre legible que aparece en las alertas
BANK_PAYMENT_TYPE=BankPayType   # identifier del banco (ver discover_paytypes.py)
BANK_DISPLAY_NAME=Nombre del Banco
ASSET=USDT                 # cripto a comprar
FIAT=USD                   # moneda fiat del banco (ej. USD, VES, PEN)

# ─── Alertas ───────────────────────────────────────────────
PRICE_THRESHOLD=0.998          # alertar cuando el precio <= este valor (en FIAT)
ORDER_AMOUNT_USD=300           # filtra ofertas que permitan comprar este monto (en FIAT)
POLL_INTERVAL_SECONDS=60
COOLDOWN_MINUTES=30            # evita spam de notificaciones

# ─── Email (Gmail SMTP) ────────────────────────────────────
EMAIL_ENABLED=true
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App Password, NO la contraseña normal
ALERT_EMAIL=tu_correo@gmail.com          # destino de las alertas

# ─── Telegram (Bot API) — recomendado: instantáneo y confiable ─
# TELEGRAM_BOT_TOKEN: token de @BotFather (ej. 123456:ABC-DEF...)
# TELEGRAM_CHAT_ID: lo descubre `.venv/bin/python telegram_sender.py`
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── WhatsApp (CallMeBot) — opcional ───────────────────────
WHATSAPP_ENABLED=false
CALLMEBOT_PHONE=+507xxxxxxxx     # tu número con código de país
CALLMEBOT_APIKEY=xxxxxxx         # key recibida en el setup manual

# ─── Operación ─────────────────────────────────────────────
DRY_RUN=false                  # true = loguea sin enviar nada
